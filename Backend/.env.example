# ===== Database =====
# 로컬 개발 (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./text_to_3d.db
# Supabase 배포 시 (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://postgres.[프로젝트ref]:[비밀번호]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# ===== JWT =====
JWT_SECRET_KEY=여기에-랜덤-시크릿키-입력
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ===== LLM Server (AI팀) =====
LLM_SERVER_URL=http://localhost:8001
LLM_REQUEST_TIMEOUT=120

# ===== TRELLIS 3D Server (3D팀) =====
TRELLIS_SERVER_URL=http://localhost:8002
TRELLIS_REQUEST_TIMEOUT=300

# ===== File Storage =====
STORAGE_PATH=./storage
# Supabase 배포 시 아래 세 줄 주석 해제 후 값 입력
# SUPABASE_URL=https://[프로젝트ref].supabase.co
# SUPABASE_KEY=[anon public key]
# SUPABASE_BUCKET_NAME=platform-storage
